<Window x:Class="DTC.New.WPF.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:DTC.New.WPF"
        xmlns:views="clr-namespace:DTC.New.WPF.Views"
        xmlns:pages="clr-namespace:DTC.New.WPF.Views.Pages"
        xmlns:vmPages="clr-namespace:DTC.New.WPF.ViewModels.Pages"
        Title="DTC for DCS"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True"
        ResizeMode="CanResizeWithGrip"
        Width="850" Height="660"
        MinWidth="700" MinHeight="500">

    <Window.Resources>
        <local:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter" />

        <!-- DataTemplate routing: maps each ViewModel type to its View -->
        <DataTemplate DataType="{x:Type vmPages:MainPageViewModel}">
            <pages:MainPageView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vmPages:PresetsViewModel}">
            <pages:PresetsPageView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vmPages:AircraftViewModel}">
            <pages:AircraftShellView />
        </DataTemplate>
    </Window.Resources>

    <!-- Outer border for rounded corners and drop shadow -->
    <Border Background="{StaticResource BackgroundDarkBrush}"
            BorderBrush="{StaticResource BorderBrush}"
            BorderThickness="1"
            CornerRadius="6">
        <Border.Effect>
            <DropShadowEffect Color="Black" BlurRadius="18" ShadowDepth="4" Opacity="0.6" />
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="32" />     <!-- Title bar -->
                <RowDefinition Height="32" />     <!-- Breadcrumb -->
                <RowDefinition Height="1" />      <!-- Separator -->
                <RowDefinition Height="*" />      <!-- Page content -->
                <RowDefinition Height="Auto" />   <!-- Bottom action bar -->
            </Grid.RowDefinitions>

            <!-- ═══════════════ TITLE BAR ═══════════════ -->
            <Grid Grid.Row="0"
                  Background="{StaticResource TitleBarBrush}"
                  MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center" Margin="12,0,0,0">
                    <TextBlock Text="DTC" FontSize="13" FontWeight="Bold"
                               Foreground="{StaticResource AccentGreenBrightBrush}"
                               FontFamily="{StaticResource MonoFont}" />
                    <TextBlock Text=" for DCS" FontSize="13"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               FontFamily="{StaticResource UIFont}" />
                    <TextBlock Text="{Binding Version}" FontSize="10"
                               Foreground="{StaticResource TextDisabledBrush}"
                               VerticalAlignment="Bottom" Margin="8,0,0,2"
                               FontFamily="{StaticResource UIFont}" />
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button x:Name="btnMinimize"
                            Style="{StaticResource TitleBarButtonStyle}"
                            Content="─"
                            Click="BtnMinimize_Click"
                            ToolTip="Minimize" />
                    <Button x:Name="btnPin"
                            Style="{StaticResource TitleBarButtonStyle}"
                            Click="BtnPin_Click"
                            ToolTip="Always on top">
                        <Button.Content>
                            <TextBlock x:Name="pinIcon" Text="📍" FontSize="12" />
                        </Button.Content>
                    </Button>
                    <Button x:Name="btnClose"
                            Style="{StaticResource TitleBarCloseButtonStyle}"
                            Content="✕"
                            Click="BtnClose_Click"
                            ToolTip="Close" />
                </StackPanel>
            </Grid>

            <!-- ═══════════════ BREADCRUMB ═══════════════ -->
            <views:BreadcrumbBar Grid.Row="1"
                                 ItemsSource="{Binding Navigation.Breadcrumbs}"
                                 Background="{StaticResource BackgroundMidBrush}" />

            <!-- ═══════════════ SEPARATOR ═══════════════ -->
            <Rectangle Grid.Row="2" Fill="{StaticResource SeparatorBrush}" />

            <!-- ═══════════════ PAGE CONTENT ═══════════════ -->
            <ContentControl Grid.Row="3"
                            Content="{Binding Navigation.Current}"
                            Background="{StaticResource BackgroundDarkBrush}" />

            <!-- ═══════════════ BOTTOM ACTION BAR ═══════════════ -->
            <Border Grid.Row="4"
                    Background="{StaticResource BackgroundMidBrush}"
                    BorderBrush="{StaticResource SeparatorBrush}"
                    BorderThickness="0,1,0,0"
                    Padding="12,8"
                    Visibility="{Binding ShowBottomBar, Converter={StaticResource BoolToVisibilityConverter}}">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="KNEEBOARD"
                            Style="{StaticResource DTCButtonStyle}"
                            Command="{Binding ShowKneeboardCommand}"
                            Width="120" Height="30"
                            Margin="0,0,8,0" />
                    <Button Content="▶  UPLOAD TO JET"
                            Style="{StaticResource DTCPrimaryButtonStyle}"
                            Command="{Binding ExecuteUploadCommand}"
                            Width="160" Height="30" />
                </StackPanel>
            </Border>

        </Grid>
    </Border>
</Window>
