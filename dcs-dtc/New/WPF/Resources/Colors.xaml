<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Background layers -->
    <Color x:Key="BackgroundDarkColor">#FF151515</Color>
    <Color x:Key="BackgroundMidColor">#FF1E1E1E</Color>
    <Color x:Key="BackgroundLightColor">#FF282828</Color>
    <Color x:Key="BackgroundPanelColor">#FF222222</Color>
    <Color x:Key="TitleBarColor">#FF111111</Color>

    <!-- Accent: military green -->
    <Color x:Key="AccentGreenColor">#FF4A7C4E</Color>
    <Color x:Key="AccentGreenBrightColor">#FF6FAF75</Color>
    <Color x:Key="AccentGreenDimColor">#FF2E5030</Color>

    <!-- Accent: amber/warning -->
    <Color x:Key="AccentAmberColor">#FFCC8800</Color>
    <Color x:Key="AccentAmberBrightColor">#FFFFAA00</Color>

    <!-- Accent: danger/close -->
    <Color x:Key="AccentRedColor">#FFA83232</Color>

    <!-- Text -->
    <Color x:Key="TextPrimaryColor">#FFE8E8E8</Color>
    <Color x:Key="TextSecondaryColor">#FF999999</Color>
    <Color x:Key="TextDisabledColor">#FF555555</Color>
    <Color x:Key="TextAccentColor">#FF6FAF75</Color>

    <!-- Borders & separators -->
    <Color x:Key="BorderColor">#FF3A3A3A</Color>
    <Color x:Key="BorderActiveColor">#FF4A7C4E</Color>
    <Color x:Key="SeparatorColor">#FF2A2A2A</Color>

    <!-- Selection / hover -->
    <Color x:Key="SelectionBackgroundColor">#FF2A4A2E</Color>
    <Color x:Key="HoverBackgroundColor">#FF303030</Color>
    <Color x:Key="PressedBackgroundColor">#FF1A3A1E</Color>

    <!-- Input controls -->
    <Color x:Key="InputBackgroundColor">#FF1A1A1A</Color>
    <Color x:Key="InputBorderColor">#FF404040</Color>
    <Color x:Key="InputBorderFocusColor">#FF4A7C4E</Color>

    <!-- SolidColorBrush versions -->
    <SolidColorBrush x:Key="BackgroundDarkBrush"     Color="{StaticResource BackgroundDarkColor}" />
    <SolidColorBrush x:Key="BackgroundMidBrush"      Color="{StaticResource BackgroundMidColor}" />
    <SolidColorBrush x:Key="BackgroundLightBrush"    Color="{StaticResource BackgroundLightColor}" />
    <SolidColorBrush x:Key="BackgroundPanelBrush"    Color="{StaticResource BackgroundPanelColor}" />
    <SolidColorBrush x:Key="TitleBarBrush"           Color="{StaticResource TitleBarColor}" />

    <SolidColorBrush x:Key="AccentGreenBrush"        Color="{StaticResource AccentGreenColor}" />
    <SolidColorBrush x:Key="AccentGreenBrightBrush"  Color="{StaticResource AccentGreenBrightColor}" />
    <SolidColorBrush x:Key="AccentGreenDimBrush"     Color="{StaticResource AccentGreenDimColor}" />
    <SolidColorBrush x:Key="AccentAmberBrush"        Color="{StaticResource AccentAmberColor}" />
    <SolidColorBrush x:Key="AccentAmberBrightBrush"  Color="{StaticResource AccentAmberBrightColor}" />
    <SolidColorBrush x:Key="AccentRedBrush"          Color="{StaticResource AccentRedColor}" />

    <SolidColorBrush x:Key="TextPrimaryBrush"        Color="{StaticResource TextPrimaryColor}" />
    <SolidColorBrush x:Key="TextSecondaryBrush"      Color="{StaticResource TextSecondaryColor}" />
    <SolidColorBrush x:Key="TextDisabledBrush"       Color="{StaticResource TextDisabledColor}" />
    <SolidColorBrush x:Key="TextAccentBrush"         Color="{StaticResource TextAccentColor}" />

    <SolidColorBrush x:Key="BorderBrush"             Color="{StaticResource BorderColor}" />
    <SolidColorBrush x:Key="BorderActiveBrush"       Color="{StaticResource BorderActiveColor}" />
    <SolidColorBrush x:Key="SeparatorBrush"          Color="{StaticResource SeparatorColor}" />

    <SolidColorBrush x:Key="SelectionBackgroundBrush" Color="{StaticResource SelectionBackgroundColor}" />
    <SolidColorBrush x:Key="HoverBackgroundBrush"    Color="{StaticResource HoverBackgroundColor}" />
    <SolidColorBrush x:Key="PressedBackgroundBrush"  Color="{StaticResource PressedBackgroundColor}" />

    <SolidColorBrush x:Key="InputBackgroundBrush"    Color="{StaticResource InputBackgroundColor}" />
    <SolidColorBrush x:Key="InputBorderBrush"        Color="{StaticResource InputBorderColor}" />
    <SolidColorBrush x:Key="InputBorderFocusBrush"   Color="{StaticResource InputBorderFocusColor}" />

    <!-- Transparent brush -->
    <SolidColorBrush x:Key="TransparentBrush"        Color="Transparent" />

</ResourceDictionary>
