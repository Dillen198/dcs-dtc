<UserControl x:Class="DTC.New.WPF.Views.Pages.AircraftShellView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vmPages="clr-namespace:DTC.New.WPF.ViewModels.Pages"
             Background="{StaticResource BackgroundDarkBrush}">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="175" />  <!-- Sidebar -->
            <ColumnDefinition Width="1" />    <!-- Divider -->
            <ColumnDefinition Width="*" />    <!-- Content -->
        </Grid.ColumnDefinitions>

        <!-- ══════════════════ LEFT SIDEBAR ══════════════════ -->
        <Border Grid.Column="0"
                Background="{StaticResource BackgroundMidBrush}"
                BorderBrush="{StaticResource SeparatorBrush}"
                BorderThickness="0,0,1,0">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <ItemsControl x:Name="tabList"
                              ItemsSource="{Binding Tabs}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate DataType="{x:Type vmPages:SystemTabItem}">
                            <ContentPresenter x:Name="PART_Content" />
                            <DataTemplate.Triggers>
                                <DataTrigger Binding="{Binding IsDivider}" Value="True">
                                    <Setter TargetName="PART_Content" Property="ContentTemplate">
                                        <Setter.Value>
                                            <DataTemplate>
                                                <Separator Style="{StaticResource DTCSeparatorStyle}" Margin="8,2" />
                                            </DataTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding IsDivider}" Value="False">
                                    <Setter TargetName="PART_Content" Property="ContentTemplate">
                                        <Setter.Value>
                                            <DataTemplate DataType="{x:Type vmPages:SystemTabItem}">
                                                <ToggleButton
                                                    Style="{StaticResource SystemTabButtonStyle}"
                                                    Content="{Binding Title}"
                                                    IsChecked="{Binding IsSelected, Mode=TwoWay}"
                                                    Click="SystemTab_Click"
                                                    Tag="{Binding}" />
                                            </DataTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </DataTrigger>
                            </DataTemplate.Triggers>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Border>

        <!-- ══════════════════ SEPARATOR ══════════════════ -->
        <Rectangle Grid.Column="1" Fill="{StaticResource SeparatorBrush}" />

        <!-- ══════════════════ CONTENT (WindowsFormsHost) ══════════════════ -->
        <Border Grid.Column="2"
                Background="{StaticResource BackgroundDarkBrush}">
            <!-- The WindowsFormsHost is created in code-behind and injected here -->
            <ContentPresenter x:Name="PART_ContentHost" />
        </Border>

    </Grid>
</UserControl>
